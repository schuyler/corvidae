# LLM backend — OpenAI-compatible Chat Completions API (required)
# llm.main is required. llm.background is optional; if absent, background
# tasks use llm.main.
llm:
  main:
    base_url: http://localhost:8080/v1   # llama-server, vLLM, OpenAI, etc.
    model: llama3                     # model name as the backend expects it
    # api_key: sk-...                 # omit for local servers
    # extra_body:                      # optional: provider-specific request payload extensions
    #   id_slot: 0                      # example: llama.cpp KV cache slot for parallelism
    # max_retries: 3                   # max retry attempts on transient errors (429, 500, 502, 503, 504)
    # retry_base_delay: 2.0            # base delay in seconds for exponential backoff
    # retry_max_delay: 60.0            # maximum delay cap in seconds
    # timeout: null                    # HTTP timeout in seconds per request (null uses aiohttp's 300s default)
  # background:                        # optional: separate LLM for background tasks
  #   base_url: http://localhost:8080   # all fields must be specified; no inheritance from llm.main
  #   model: llama3
  #   # api_key: sk-...                 # omit for local servers
  #   # extra_body:
  #   #   id_slot: 1
  #   # max_retries: 3
  #   # retry_base_delay: 2.0
  #   # retry_max_delay: 60.0
  #   # timeout: null

# Daemon settings (optional)
daemon:
  session_db: sessions.db           # SQLite path for conversation history
  # max_task_workers: 4             # concurrent background task workers
  # completed_task_buffer: 100      # completed tasks retained in memory
  # idle_cooldown_seconds: 30       # minimum seconds between on_idle firings
  # idle_poll_interval: 2           # seconds between idle-state checks

# Agent-level defaults — apply to all channels unless overridden (optional)
agent:
  system_prompt: "You are a helpful assistant."
  max_context_tokens: 64000
  keep_thinking_in_history: false
  # max_turns: 10                   # max consecutive tool-calling turns per message
  # max_tool_result_chars: 100000   # truncate tool results beyond this length
  # compaction_threshold: 0.8       # compact when token estimate exceeds this × max_context_tokens
  # compaction_retention: 0.5       # after compaction, retain this fraction of token budget
  #                                    ⚠ Must be significantly less than compaction_threshold.
  #                                    If retention ≥ threshold, compaction is a no-op and the agent
  #                                    will re-compact every few messages without reducing context.
  # min_messages_to_compact: 5      # skip compaction with this many messages or fewer
  # chars_per_token: 3.5            # character-to-token ratio for token estimation
  # immutable_settings:             # keys the agent cannot change via set_settings (system_prompt always blocked)
  #   - max_turns                   # example: prevent the agent from extending its own turn limit

# Built-in tool settings (optional)
# tools:
#   shell_timeout: 30               # seconds before shell command is killed
#   web_fetch_timeout: 15           # seconds before HTTP request is aborted
#   web_max_response_bytes: 50000   # max bytes of HTTP response body
#   max_file_read_bytes: 1048576    # max file size for read_file (1 MB)

# IRC transport connection settings (optional — omit to disable IRC)
# irc:
#   host: irc.libera.chat              # IRC server hostname
#   port: 6667                         # IRC server port
#   nick: sherman                      # bot nickname
#   tls: false                         # use TLS (set port to 6697 with tls: true)
#   message_chunk_size: 400            # max UTF-8 bytes per outbound message
#   channels:                          # channels to auto-join
#     - "#general"
#     - "#random"

# Logging (optional)
# logging:
#   level: INFO                # DEBUG | INFO | WARNING | ERROR | CRITICAL
#   file: corvidae.log         # log to file; omit for stderr (CLI defaults to file)

# Per-channel config (optional)
# Keys must be "transport:scope". Overrides agent defaults where set.
channels:
  cli:local:
    system_prompt: "You are a helpful assistant running in CLI mode."
  # irc:#lex:
  #   system_prompt: "You are Sherman, an IRC bot in #lex."
  #   max_context_tokens: 8000
  # signal:+15551234567:
  #   keep_thinking_in_history: true
