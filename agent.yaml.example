# LLM backend — OpenAI-compatible Chat Completions API (required)
# llm.main is required. llm.background is optional; if absent, background
# tasks use llm.main.
llm:
  main:
    base_url: http://localhost:8080   # llama-server, vLLM, OpenAI, etc.
    model: llama3                     # model name as the backend expects it
    # api_key: sk-...                 # omit for local servers
    # extra_body:                      # optional: provider-specific request payload extensions
    #   id_slot: 0                      # example: llama.cpp KV cache slot for parallelism
  # background:                        # optional: separate LLM for background tasks
  #   base_url: http://localhost:8080
  #   model: llama3
  #   # extra_body:
  #   #   id_slot: 1

# Daemon settings (optional)
daemon:
  session_db: sessions.db           # SQLite path for conversation history

# Agent-level defaults — apply to all channels unless overridden (optional)
agent:
  system_prompt: "You are a helpful assistant."
  max_context_tokens: 24000
  keep_thinking_in_history: false

# Per-channel config (optional)
# Keys must be "transport:scope". Overrides agent defaults where set.
channels:
  cli:local:
    system_prompt: "You are a helpful assistant running in CLI mode."
  # irc:#lex:
  #   system_prompt: "You are Sherman, an IRC bot in #lex."
  #   max_context_tokens: 8000
  # signal:+15551234567:
  #   keep_thinking_in_history: true
